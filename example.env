# ═══════════════════════════════════════════════════════════════
# TRACE Configuration — Example
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
TRACE_HOST=0.0.0.0
TRACE_PORT=8000

# ── Database ────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./trace.db
# PostgreSQL (uncomment for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/trace_db

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all (development)
CORS_ORIGINS=*

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-string
