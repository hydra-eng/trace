# ═══════════════════════════════════════════════════════════════
# TRACE .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Environment files (sensitive — never commit) ────────────
.env
.env.local
.env.*.local
!example.env

# ── Virtual environments ────────────────────────────────────
trace-backend/.venv/
trace-frontend/.venv/
.venv/
venv/
env/

# ── Python cache ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# ── SQLite databases (contain actual case data) ────────────
trace-backend/trace.db
trace-backend/*.db
trace-backend/*.db-journal
trace-backend/*.db-shm
trace-backend/*.db-wal

# ── Node modules & build output ─────────────────────────────
trace-frontend/node_modules/
trace-frontend/dist/
trace-frontend/dist-ssr/
trace-frontend/*.local
trace-frontend/.eslintcache

# ── Firebase ────────────────────────────────────────────────
.firebase/

# ── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo

# ── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ────────────────────────────────────────────────────
*.log
logs/
trace-frontend/logs/
trace-backend/logs/
